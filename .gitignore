# ─── Vendored third-party SDK clones (huge; users clone these themselves) ───
ESP_HaLow/
mm-iot-esp32/

# ─── Debug/experiment scratch, not part of the project ───
HD01/
esphome/

# ─── Build outputs & staged libraries ───
.pio/
*.obj
# Root-level staged Morse/lwIP libs and chip firmware (build inputs, not source)
/*.a
/*.mbin
/*.mbin.*
/mm6108*.mbin*

# ─── Python ───
__pycache__/
*.pyc
.venv/
venv/

# ─── Secrets & machine-specific config (never commit) ───
web-server/secrets.toml
web-server/mowers.toml
*.toml.tmp
# Generated launchers (absolute paths baked in by install.py) — .example stays tracked
web-server/run-server.bat
web-server/run-server.sh
# Firmware runtime config with real WiFi creds — config.local.ini.example stays tracked
config.local.ini
# Self-signed certs / keys generated by install.py
*.pem

# ─── Local tooling / obsolete docs (kept locally, not published) ───
.claude/settings.local.json
docs/heltec-bug-report-dbg-morselib.md
# Blog post drafts stay private (published on WordPress, not GitHub)
blog/

# ─── OS / editor cruft ───
.DS_Store
Thumbs.db
